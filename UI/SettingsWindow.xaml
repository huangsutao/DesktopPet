<Window x:Class="DesktopPet.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings.Title}"
        Width="500"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabs" Grid.Row="0" Padding="0">
            <TabItem Header="{DynamicResource Settings.Tab.General}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12,12,4">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.Language}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="LanguageCombo" Margin="0,0,0,4" />
                        <TextBlock Text="{DynamicResource Settings.Language.Hint}"
                                   Foreground="Gray"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />

                        <TextBlock Text="{DynamicResource Settings.CurrentPet}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock x:Name="CurrentPetText" Margin="0,0,0,4" />
                        <TextBlock Text="{DynamicResource Settings.PetSwitchHint}"
                                   Foreground="Gray"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />

                        <TextBlock Text="{DynamicResource Settings.Scale}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock x:Name="ScaleValueText"
                                       DockPanel.Dock="Right"
                                       Width="40"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="ScaleSlider"
                                    Minimum="0.1"
                                    Maximum="1.5"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="ScaleSlider_OnValueChanged" />
                        </DockPanel>

                        <CheckBox x:Name="TopmostCheck" Content="{DynamicResource Settings.Topmost}" Margin="0,0,0,12" />

                        <CheckBox x:Name="ClickThroughCheck" Content="{DynamicResource Settings.ClickThrough}" Margin="0,0,0,4" />
                        <TextBlock Text="{DynamicResource Settings.ClickThrough.Hint}"
                                   Foreground="Gray"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Settings.Tab.Walk}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12,12,4">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.WalkArea}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="WalkModeCombo"
                                  Margin="0,0,0,8"
                                  SelectionChanged="WalkModeCombo_OnSelectionChanged">
                            <ComboBoxItem Content="{DynamicResource Settings.Walk.Mode.WorkArea}" Tag="WorkArea" />
                            <ComboBoxItem Content="{DynamicResource Settings.Walk.Mode.Inset}" Tag="Inset" />
                        </ComboBox>

                        <Grid x:Name="InsetMarginsPanel" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Settings.Margin.Left}" VerticalAlignment="Center" Margin="0,0,8,6" />
                            <TextBox x:Name="MarginLeftBox" Grid.Row="0" Grid.Column="1" Margin="0,0,12,6" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource Settings.Margin.Top}" VerticalAlignment="Center" Margin="0,0,8,6" />
                            <TextBox x:Name="MarginTopBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Settings.Margin.Right}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="MarginRightBox" Grid.Row="1" Grid.Column="1" Margin="0,0,12,0" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource Settings.Margin.Bottom}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="MarginBottomBox" Grid.Row="1" Grid.Column="3" />
                        </Grid>

                        <TextBlock Text="{DynamicResource Settings.Autonomy}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="{DynamicResource Settings.Autonomy.Hint}"
                                   Foreground="Gray"
                                   FontSize="11"
                                   Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="64" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource Settings.Min}" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="Gray" FontSize="11" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{DynamicResource Settings.Max}" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="Gray" FontSize="11" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Settings.PauseBeforeWalk}" VerticalAlignment="Center" Margin="0,0,8,6" />
                            <TextBox x:Name="PauseBeforeWalkMinBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox x:Name="PauseBeforeWalkMaxBox" Grid.Row="1" Grid.Column="3" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Settings.PauseAfterWalk}" VerticalAlignment="Center" Margin="0,0,8,6" />
                            <TextBox x:Name="PauseAfterWalkMinBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox x:Name="PauseAfterWalkMaxBox" Grid.Row="2" Grid.Column="3" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Settings.PauseAfterAct}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="PauseAfterActMinBox" Grid.Row="3" Grid.Column="1" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBox x:Name="PauseAfterActMaxBox" Grid.Row="3" Grid.Column="3" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Settings.Tab.Sleep}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12,12,4">
                    <StackPanel>
                        <CheckBox x:Name="SleepEnabledCheck"
                                  Content="{DynamicResource Settings.Sleep.Enabled}"
                                  Margin="0,0,0,8"
                                  Checked="SleepEnabledCheck_OnChanged"
                                  Unchecked="SleepEnabledCheck_OnChanged" />
                        <TextBlock Text="{DynamicResource Settings.Sleep.Hint}"
                                   Foreground="Gray"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <DockPanel x:Name="SleepIdlePanel">
                            <TextBlock Text="{DynamicResource Settings.Sleep.IdleSeconds}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBox x:Name="SleepIdleSecondsBox" Width="80" HorizontalAlignment="Left" />
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Settings.Tab.Bubble}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12,12,4">
                    <StackPanel>
                        <CheckBox x:Name="BubbleEnabledCheck"
                                  Content="{DynamicResource Settings.Bubble.Enabled}"
                                  Margin="0,0,0,8" />
                        <TextBlock Text="{DynamicResource Settings.Bubble.Hint}"
                                   Foreground="Gray"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Settings.Tab.Ai}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12,12,4">
                    <StackPanel>
                        <CheckBox x:Name="AiEnabledCheck"
                                  Content="{DynamicResource Settings.Ai.Enabled}"
                                  Margin="0,0,0,8"
                                  Checked="AiEnabledCheck_OnChanged"
                                  Unchecked="AiEnabledCheck_OnChanged" />
                        <TextBlock Text="{DynamicResource Settings.Ai.Hint}"
                                   Foreground="Gray"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <StackPanel x:Name="AiParamsPanel">
                            <TextBlock Text="{DynamicResource Settings.Ai.Url}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBox x:Name="AiUrlBox" Margin="0,0,0,4" />
                            <TextBlock Text="{DynamicResource Settings.Ai.Url.Hint}"
                                       Foreground="Gray"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="{DynamicResource Settings.Ai.ApiKey}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <PasswordBox x:Name="AiApiKeyBox" Margin="0,0,0,12" />

                            <TextBlock Text="{DynamicResource Settings.Ai.ModelId}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBox x:Name="AiModelIdBox" Margin="0,0,0,12" />

                            <TextBlock Text="{DynamicResource Settings.Ai.Location}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Ai.Country}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="AiCountryBox" Grid.Column="1" Margin="0,0,12,0" />
                                <TextBlock Grid.Column="2" Text="{DynamicResource Settings.Ai.City}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="AiCityBox" Grid.Column="3" />
                            </Grid>
                            <TextBlock Text="{DynamicResource Settings.Ai.Location.Hint}"
                                       Foreground="Gray"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="{DynamicResource Settings.Ai.Prompt.Hint}"
                                       Foreground="Gray"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource Settings.Cancel}" Width="80" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click" />
            <Button Content="{DynamicResource Settings.Save}" Width="80" IsDefault="True" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
